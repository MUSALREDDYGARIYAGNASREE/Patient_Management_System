<style>
  .notice {
    color: green;
    font-weight: bold;
    margin-bottom: 20px;
  }

  .appointment-details {
    border: 1px solid #ddd;
    padding: 20px;
    border-radius: 8px;
    background-color: #fdfdfd;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
    margin-bottom: 20px;
  }

  .appointment-actions {
    margin-top: 20px;
  }

  .appointment-actions a,
  .appointment-actions form {
    margin-right: 12px;
    display: inline-block;
  }

  .link-btn {
    background-color: #2d6cdf;
    color: white;
    padding: 8px 16px;
    text-decoration: none;
    border-radius: 4px;
  }

  .link-btn:hover {
    background-color: #1b4fbf;
  }

  .delete-btn {
    background-color: #e74c3c;
    color: white;
    padding: 8px 16px;
    border: none;
    border-radius: 4px;
  }

  .delete-btn:hover {
    background-color: #c0392b;
  }
</style>

<% if notice %>
  <p class="notice"><%= notice %></p>
<% end %>

<div class="appointment-details">
  <%= render @appointment %>
</div>

<div class="appointment-actions">
  <%= link_to "Edit this appointment", edit_appointment_path(@appointment), class: "link-btn" %>
  <%= link_to "Back to appointments", appointments_path, class: "link-btn" %>

  <%= button_to "Destroy this appointment", @appointment, method: :delete, class: "delete-btn", data: { confirm: "Are you sure?" } %>
</div>
