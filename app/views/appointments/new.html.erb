<% content_for :title, "New Appointment" %>

<style>
  .page-header {
    font-size: 2rem;
    font-weight: bold;
    color: #2c3e50;
    margin-bottom: 20px;
  }

  .form-container {
    background-color: #fefefe;
    padding: 25px;
    border: 1px solid #ddd;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    max-width: 600px;
    margin-bottom: 30px;
  }

  .back-link {
    background-color: #3498db;
    color: white;
    padding: 8px 14px;
    border-radius: 6px;
    text-decoration: none;
  }

  .back-link:hover {
    background-color: #2c80b4;
  }
</style>

<h1 class="page-header">➕ New Appointment</h1>

<div class="form-container">
  <%= render "form", appointment: @appointment %>
</div>

<%= link_to "← Back to Appointments", appointments_path, class: "back-link" %>
