<%= form_with(model: appointment, local: true) do |form| %>
  <% if appointment.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(appointment.errors.count, "error") %> prohibited this appointment from being saved:</h2>
      <ul>
        <% appointment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :patient_id, "Select Patient" %>
    <%= form.collection_select :patient_id, Patient.all, :id, :name, {}, { class: "form-control" } %>
  </div>

  <div class="form-group">
    <%= form.label :date %>
    <%= form.date_field :date, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :time %>
    <%= form.time_field :time, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :purpose %>
    <%= form.text_area :purpose, class: "form-control" %>
  </div>

  <div class="form-actions">
    <%= form.submit "Schedule Appointment", class: "btn-submit" %>
  </div>
<% end %>
