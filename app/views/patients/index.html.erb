<p class="notice-message"><%= notice %></p>

<% content_for :title, "Patients" %>

<h1 class="page-heading">Patients</h1>

<!-- 🔍 Search and Filter Form -->
<%= form_with url: patients_path, method: :get, local: true, html: { class: "filter-form" } do %>
  <div class="form-group">
    <label>Search by Name:</label>
    <%= text_field_tag :query, params[:query], class: "form-input" %>
  </div>

  <div class="form-group">
    <label>Min Age:</label>
    <%= number_field_tag :min_age, params[:min_age], class: "form-input" %>
  </div>

  <div class="form-group">
    <label>Max Age:</label>
    <%= number_field_tag :max_age, params[:max_age], class: "form-input" %>
  </div>

  <%= submit_tag "Filter", class: "form-button" %>
<% end %>

<!-- 🧾 List of Patients -->
<div class="patient-list">
  <% @patients.each do |patient| %>
    <div class="patient-card">
      <%= render patient %>
      <p><%= link_to "Show this patient", patient, class: "link-button" %></p>
    </div>
  <% end %>
</div>

<div class="new-patient-button">
  <%= link_to "➕ New Patient", new_patient_path, class: "form-button green" %>
</div>
