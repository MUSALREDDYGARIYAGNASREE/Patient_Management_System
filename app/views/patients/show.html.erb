<p class="notice-message"><%= notice %></p>

<%= render @patient %>

<div class="action-links">
  <%= link_to "✏️ Edit this patient", edit_patient_path(@patient), class: "action-link" %>
  |
  <%= link_to "⬅️ Back to patients", patients_path, class: "action-link" %>
  |
  <%= button_to "🗑️ Destroy this patient", @patient, method: :delete, data: { confirm: "Are you sure?" }, class: "danger-button" %>
</div>

<h2 class="section-heading">📋 Appointments</h2>
<div class="new-appointment-link">
  <%= link_to "➕ New Appointment", new_appointment_path(patient_id: @patient.id), class: "form-button green" %>
</div>

<ul class="appointments-list">
  <% @patient.appointments.each do |appt| %>
    <li class="appointment-item">
      <strong><%= appt.date %> <%= appt.time.strftime("%I:%M %p") %>:</strong>
      <span><%= appt.purpose %></span>
    </li>
  <% end %>
</ul>
