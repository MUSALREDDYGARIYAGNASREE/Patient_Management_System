<div class="dashboard-container">
  <h1 class="dashboard-title">Receptionist Dashboard</h1>

  <div class="stat-box stat-box-blue">
    <h2>📋 Total Patients: 
      <span class="stat-number"><%= @total_patients %></span>
    </h2>
  </div>

  <div class="stat-box stat-box-green">
    <h2>🗓️ Today's Appointments: 
      <span class="stat-number"><%= @todays_appointments %></span>
    </h2>
  </div>

  <div class="button-grid">
    <%= button_to "Manage Patients", patients_path, method: :get, class: "action-button blue" %>
    <%= button_to "Add New Patient", new_patient_path, method: :get, class: "action-button green" %>
    <%= button_to "Schedule Appointment", new_appointment_path, method: :get, class: "action-button indigo" %>
    <%= button_to "View All Appointments", appointments_path, method: :get, class: "action-button gray" %>
  </div>
</div>
